# PostgreSQL connection (matches docker-compose.yml — host port 5434)
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/sql_assistant"

# OpenAI — REQUIRED for natural-language -> SQL generation.
# (Prompt-to-SQL is the core of this task, so a valid key is needed to ask questions.
#  Upload, schema detection, table creation and SQL execution all work without it.)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
