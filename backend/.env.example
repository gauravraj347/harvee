# PostgreSQL connection (matches ../docker-compose.yml — host port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/course_allocation?schema=public"

# OpenAI — required only for the AI Assistant.
# The dashboard and all analytics work without it; if this key is missing,
# the assistant falls back to a built-in rule-based matcher for the core questions.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# API server
PORT=4000
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN="http://localhost:3000"
